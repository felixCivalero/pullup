{
  "name": "backend",
  "type": "module",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/index.js",
    "start": "node src/index.js",
    "worker": "node src/email/outbox/outboxWorkerRunner.js",
    "worker:once": "node src/email/outbox/outboxWorkerRunner.js --mode=once",
    "test": "fail=0; for f in tests/*.test.js; do echo \"\\n--- $f ---\"; node \"$f\" || fail=1; done; exit $fail",
    "e2e": "node scripts/e2e-core-flows.mjs",
    "scan:queries": "node scripts/scan-queries.mjs",
    "probes": "node scripts/verify-room-view.mjs && node scripts/verify-metrics.mjs && node scripts/verify-rsvp.mjs && node scripts/verify-publish.mjs",
    "probe:act-as": "node scripts/verify-act-as.mjs",
    "probe:payments": "node scripts/verify-payments-v2.mjs",
    "probe:byo": "node scripts/verify-byo-router.mjs",
    "probe:byo-mirror": "node scripts/verify-byo-mirror.mjs",
    "probe:byo-provision": "node scripts/verify-byo-provision.mjs",
    "probe:byo-live": "node scripts/verify-byo-live.mjs",
    "probe:byo-mgmt": "node scripts/verify-byo-mgmt.mjs"
  },
