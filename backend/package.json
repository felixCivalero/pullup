    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-sesv2": "^3.598.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/node": "^10.60.0",
    "@supabase/supabase-js": "^2.87.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.3",
    "mailparser": "^3.9.9",
    "resend": "^6.6.0",
    "sns-validator": "^0.3.5",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.11"
  }
